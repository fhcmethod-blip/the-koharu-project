# Copy to .env.local (gitignored)

# === AUTH (email + password) ===
# Required for signed sessions (openssl rand -hex 32)
AUTH_SECRET=
# Public site URL (Stripe redirects, absolute links)
NEXT_PUBLIC_APP_URL=https://thekoharuproject.com
# Postgres (Neon free) — required on Vercel so accounts persist
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# === STRIPE (Plus / VIP subscriptions) ===
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PLUS=price_...
# STRIPE_PRICE_VIP=price_...

# === CHAT (OpenRouter) — text only ===
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-70b
OPENROUTER_SITE_URL=https://thekoharuproject.com
OPENROUTER_SITE_NAME=The Koharu Project

# === IMAGE GEN (separate from chat) — Fooocus default ===
IMAGE_PROVIDER=fooocus
FOOOCUS_API_URL=http://127.0.0.1:8888
# Public tunnel (phones / Vercel):
# FOOOCUS_API_URL=https://fooocus.thekoharuproject.com
# NEXT_PUBLIC_FOOOCUS_API_URL=https://fooocus.thekoharuproject.com
FOOOCUS_ASPECT=896*1152
FOOOCUS_PERFORMANCE=Quality
FOOOCUS_DEFAULT_MODE=realistic
FOOOCUS_MODEL=juggernautXL_v8Rundiffusion.safetensors
FOOOCUS_DEFAULT_SCENE=fully nude hardcore sex, penetration, explicit, photorealistic young adult 18-20, natural lighting, side angle, eyes closed, not a selfie

# REQUIRED when tunnel is public — same value on PC bridge + Vercel
# Generate: openssl rand -hex 24
FOOOCUS_BRIDGE_SECRET=
# Browser→tunnel jobs (mobile) need the same secret client-side:
NEXT_PUBLIC_FOOOCUS_BRIDGE_SECRET=

# Optional: Pony via A1111 instead
# IMAGE_PROVIDER=pony
# PONY_API_URL=http://127.0.0.1:7860
