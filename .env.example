# Copy to .env.local (gitignored)

# === CHAT (OpenRouter) — text only ===
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-70b
OPENROUTER_SITE_URL=https://thekoharuproject.com
OPENROUTER_SITE_NAME=The Koharu Project

# === IMAGE GEN (separate from chat) — Fooocus default ===
IMAGE_PROVIDER=fooocus
FOOOCUS_API_URL=http://127.0.0.1:8888
FOOOCUS_ASPECT=896*1152
FOOOCUS_PERFORMANCE=Speed
FOOOCUS_DEFAULT_SCENE=nude selfie, bedroom, explicit nsfw, looking at viewer

# Optional: Pony via A1111 instead
# IMAGE_PROVIDER=pony
# PONY_API_URL=http://127.0.0.1:7860
